CompileFlags:
  CompilationDatabase: build
  # Strip GCC-only or otherwise noisy options that clang can't handle.
  Remove:
    - -fno-printf-return-value
    - -mfp16-format=ieee
    - -fno-reorder-functions
    - -ftrack-macro-expansion=0

  # Fall back to the workspace and Zephyr source tree when the build
  # database is missing or incomplete.
  Add:
    - -Iinclude
    - -I../zephyr/include
    - -Ibuild/zephyr/include/generated
    - -fmacro-backtrace-limit=0
    - -Wno-vla-cxx-extension
    - -Wno-double-promotion
    - -Wno-float-conversion
    - -std=gnu++20
    - -xc++
Diagnostics:
  Suppress:
    - -Wunused-includes
